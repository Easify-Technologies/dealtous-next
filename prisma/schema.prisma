generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  REJECTED
}

model User {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String?
  username   String?
  email      String    @unique
  password   String
  role       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  verifyCode String?
  codeExpiry DateTime?
  isVerified Boolean   @default(false)

  products Product[]
  sessions Session[]

  buyerOrders          EscrowOrder[] @relation("BuyerOrders")
  sellerOrders         EscrowOrder[] @relation("SellerOrders")
  stripeAccountId      String?
  stripeChargesEnabled Boolean       @default(false)
  stripePayoutsEnabled Boolean       @default(false)
  reputationScore      Int           @default(0)
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  summary             String
  category            String
  currency            String
  subscribers         String
  engagementRate      String
  language            String
  postingFrequency    String
  monetizationMethods String
  averageViews        String
  price               Float
  images              String[]

  pincode String
  status  ProductStatus @default(DRAFT)

  vendorId        String   @db.ObjectId
  vendor          User     @relation(fields: [vendorId], references: [id])
  categoryDetails Category @relation(fields: [category], references: [id])

  isApproved Boolean   @default(false)
  approvedBy String?   @db.ObjectId
  approvedAt DateTime?

  orders EscrowOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  riskScore Int      @default(0)
}

model Category {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  summary String
  icon    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EscrowOrder {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [id])

  buyerId String @db.ObjectId
  buyer   User   @relation("BuyerOrders", fields: [buyerId], references: [id])

  sellerId String @db.ObjectId
  seller   User?  @relation("SellerOrders", fields: [sellerId], references: [id])

  amount Float

  stripePaymentIntentId String?
  stripeTransferId      String?

  status EscrowStatus @default(PENDING)

  payoutStatus PayoutStatus @default(HOLD)

  riskScore Int @default(0)

  releaseAfter DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disputes Dispute[]

  // ADD THESE RELATIONS
  events        OrderEvent[]
  ledger        EscrowLedger[]
  transferProof ChannelTransferProof[]
}

enum EscrowStatus {
  PENDING
  AUTHORIZED
  PAYMENT_AUTHORIZED
  SELLER_TRANSFER_PENDING
  BUYER_CONFIRMED
  RELEASE_READY
  RELEASED
  DISPUTE
  REFUNDED
  CANCELLED
}

enum PayoutStatus {
  HOLD
  READY
  PAID
}

model Dispute {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String      @db.ObjectId
  order   EscrowOrder @relation(fields: [orderId], references: [id])

  openedBy String
  reason   String

  status String @default("OPEN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  action  String
  orderId String? @db.ObjectId
  userId  String? @db.ObjectId

  metadata Json?

  createdAt DateTime @default(now())
}

model Seller {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  email              String   @unique
  stripeAccountId    String?
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model OrderEvent {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String      @db.ObjectId
  order   EscrowOrder @relation(fields: [orderId], references: [id])

  type    String
  message String?

  actorId String? @db.ObjectId

  metadata Json?

  createdAt DateTime @default(now())
}

model EscrowLedger {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String      @db.ObjectId
  order   EscrowOrder @relation(fields: [orderId], references: [id])

  type LedgerType

  amount Float

  stripePaymentIntentId String?
  stripeTransferId      String?

  createdAt DateTime @default(now())
}

enum LedgerType {
  PAYMENT_AUTHORIZED
  PAYMENT_CAPTURED
  REFUND
  TRANSFER_TO_SELLER
  STRIPE_FEE
  PLATFORM_FEE
}

model FraudSignal {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String? @db.ObjectId
  userId  String? @db.ObjectId

  signalType String
  score      Int

  metadata Json?

  createdAt DateTime @default(now())
}

model StripeWebhookEvent {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  stripeEventId String @unique

  type String

  payload Json

  processed Boolean @default(false)

  createdAt DateTime @default(now())
}

model ChannelTransferProof {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String      @db.ObjectId
  order   EscrowOrder @relation(fields: [orderId], references: [id])

  sellerScreenshot String?
  buyerScreenshot  String?

  verified Boolean @default(false)

  createdAt DateTime @default(now())
}
